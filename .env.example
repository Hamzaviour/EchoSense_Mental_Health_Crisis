# Flask
FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
JWT_SECRET_KEY=change-me-jwt-secret

# Database
DATABASE_URL=postgresql://echosense:echosense@localhost:5432/echosense

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=mental_health_knowledge
CHROMA_PATIENT_MEMORY_COLLECTION=patient_session_memory

# Embeddings (use minilm for low RAM)
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# OpenRouter
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_MODEL=openrouter/free

# Deepgram
DEEPGRAM_API_KEY=your-deepgram-key

# API Ninjas Sentiment
API_NINJAS_API_KEY=your-api-ninjas-key

# Hugging Face (dataset download)
HF_TOKEN=your-huggingface-token

# CORS
FRONTEND_URL=http://localhost:5173

# Risk engine
RISK_CLASSIFIER_ENABLED=true
SENTIMENT_CACHE_TTL=300

# Phase 2 - Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Real-time (Socket.IO enabled by default in run.py)
SOCKETIO_ENABLED=true
